PORT=3000
HOST=127.0.0.1
DATA_DIR=./data

# Vercel / hosted persistence. Add Upstash Redis from the Vercel Marketplace
# or set these manually in Project Settings -> Environment Variables.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STORAGE_PREFIX=rss-gen

# Optional hosted browser rendering. Use a Browserless/self-hosted Chrome CDP
# endpoint for JavaScript-heavy pages on Vercel.
BROWSER_WS_ENDPOINT=
BROWSER_WS_MODE=cdp
