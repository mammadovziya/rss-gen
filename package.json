{
  "name": "rss-generator",
  "version": "1.0.0",
  "description": "Local visual RSS feed builder for websites without feeds.",
  "type": "module",
  "main": "dist/server.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mammadovziya/rss-gen.git"
  },
  "homepage": "https://github.com/mammadovziya/rss-gen#readme",
  "bugs": {
    "url": "https://github.com/mammadovziya/rss-gen/issues"
  },
  "keywords": [
    "rss",
    "rss-feed",
    "rss-generator",
    "rss-builder",
    "feed-generator",
    "custom-rss",
    "visual-builder",
    "self-hosted",
    "local-first",
    "docker",
    "typescript",
    "playwright",
    "web-scraping"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsdom": "^26.1.0",
    "pino": "^9.7.0",
    "playwright": "^1.53.2",
    "rss": "^1.2.2",
    "slugify": "^1.6.6",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.0.10",
    "@types/rss": "^0.0.32",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
